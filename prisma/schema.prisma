generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "strictUndefinedChecks", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

model password {
  id             String @id @default(uuid()) @db.Uuid
  hashedPassword String
  userId         String @unique @db.Uuid
  user           user   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model user {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique
  password password?

  label         user_label?
  storage       storage?
  hubs          hub[]
  feeders       feeder[]
  rates         content_rate[]
  contents      content[]
  posts         post[]
  images        user_image[]
  likes         content_like[]
  comments      content_comment[]
  shares        share[]
  node_visits   node_visit[]
  createdGroups user_group[]
  joinedGroups  user_group_member[]
}

model user_label {
  title       String?
  description String?

  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @db.Uuid
}

model user_image {
  size Int
  data Bytes

  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.Uuid

  @@id([userId, size])
}

model node {
  id String @id @default(uuid()) @db.Uuid

  type String
  name String

  position node_position?

  hubId String @db.Uuid
  hub   hub    @relation(fields: [hubId], references: [id], onDelete: Cascade)

  feederInput  feeder? @relation("input_node", fields: [inputFeederId], references: [id], onDelete: SetNull)
  feederOutput feeder? @relation("output_node", fields: [outputFeederId], references: [id], onDelete: SetNull)

  inputFeederId  String? @unique @db.Uuid
  outputFeederId String? @unique @db.Uuid

  targetNodes node_connections[] @relation(name: "source_node")
  sourceNodes node_connections[] @relation(name: "target_node")

  rates content_rate[]

  lastShareAt DateTime?
  visits      node_visit[]

  config    node_config?
  locations node_location[]
}

model node_location {
  id String @id @default(uuid()) @db.Uuid

  node   node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId String @db.Uuid

  shares share[]

  path String @default("/") @db.Citext

  @@unique([nodeId, path])
}

model node_config {
  node   node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId String @unique @db.Uuid

  data Json
}

model node_visit {
  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
  node node @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  userId String @db.Uuid
  nodeId String @db.Uuid

  visitCount Int @default(0)

  lastVisitAt DateTime

  @@unique([userId, nodeId])
}

model node_connections {
  sourceNode   node   @relation(name: "source_node", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  sourceNodeId String @db.Uuid

  targetNode   node   @relation(name: "target_node", fields: [targetNodeId], references: [id], onDelete: Cascade)
  targetNodeId String @db.Uuid

  @@unique([sourceNodeId, targetNodeId])
}

model node_position {
  nodeId String @unique @db.Uuid
  node   node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  x      Int
  y      Int
}

model feeder {
  id String @unique @default(uuid()) @db.Uuid

  name String

  isDefault Boolean?

  userId String @db.Uuid
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  hubId String @db.Uuid
  hub   hub    @relation(fields: [hubId], references: [id], onDelete: Cascade)

  inputNode  node? @relation(name: "input_node")
  outputNode node? @relation(name: "output_node")

  stats        feeder_stats?
  permissions  feeder_permission[]
  createdPosts post[]
  ports        port_feeder[]

  @@unique([isDefault, hubId])
}

enum PermissionType {
  user_group_post_view
  user_group_post_rate
  user_group_post_share
  user_group_post_create
  user_group_post_remove
  user_group_post_comment
}

model feeder_permission {
  id String @unique @default(uuid()) @db.Uuid

  type PermissionType
  open Boolean        @default(false)

  feeder   feeder @relation(fields: [feederId], references: [id], onDelete: Cascade)
  feederId String @db.Uuid

  groups feeder_permission_group[]

  @@unique([feederId, type])
}

model feeder_permission_group {
  group   user_group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String     @db.Uuid

  permission   feeder_permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId String            @db.Uuid

  @@unique([groupId, permissionId])
}

model feeder_stats {
  feeder   feeder @relation(fields: [feederId], references: [id], onDelete: Cascade)
  feederId String @unique @db.Uuid

  postsCount Int
}

model hub {
  id String @id @default(uuid()) @db.Uuid

  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.Uuid

  isDefault Boolean?

  name String

  feeders feeder[]
  ports   port[]
  nodes   node[]
  groups  user_group[]
}

enum PortMode {
  SEND
  RECIEVE
}

model port {
  id String @id @default(uuid()) @db.Uuid

  name        String  @db.Citext
  description String?

  isDefault Boolean?

  mode PortMode

  open     Boolean @default(true)
  readonly Boolean @default(false)

  hubId String @db.Uuid
  hub   hub    @relation(fields: [hubId], references: [id], onDelete: Cascade)

  groups           port_group[]
  connectedFeeders port_feeder[]

  recievers port_subscriptions[] @relation(name: "sender_port")
  senders   port_subscriptions[] @relation(name: "reciever_port")

  @@unique([name, hubId])
  @@unique([isDefault, hubId])
}

model port_group {
  group user_group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  port  port       @relation(fields: [portId], references: [id], onDelete: Cascade)

  groupId String @db.Uuid
  portId  String @db.Uuid

  @@unique([groupId, portId])
}

model port_subscriptions {
  recieverPort port @relation(name: "reciever_port", fields: [recieverPortId], references: [id], onDelete: Cascade)
  senderPort   port @relation(name: "sender_port", fields: [senderPortId], references: [id], onDelete: Cascade)

  recieverPortId String @db.Uuid
  senderPortId   String @db.Uuid

  @@unique([recieverPortId, senderPortId])
}

model port_feeder {
  feeder feeder @relation(fields: [feederId], references: [id], onDelete: Cascade)
  port   port   @relation(fields: [portId], references: [id], onDelete: Cascade)

  feederId String @db.Uuid
  portId   String @db.Uuid

  @@unique([feederId, portId])
}

model user_group {
  id String @id @default(uuid()) @db.Uuid

  name String @db.Citext

  type String

  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.Uuid

  hubId String? @db.Uuid
  hub   hub?    @relation(fields: [hubId], references: [id], onDelete: Cascade)

  users              user_group_member[]
  port_group         port_group[]
  feeder_permissions feeder_permission_group[]

  @@unique([userId, hubId, name])
}

model user_group_member {
  group   user_group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId String     @db.Uuid

  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.Uuid

  @@id([groupId, userId])
}

model post {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   user   @relation(fields: [userId], references: [id])

  message String?

  creatorFeederId String @db.Uuid
  creatorFeeder   feeder @relation(fields: [creatorFeederId], references: [id], onDelete: Cascade)

  contentId String?  @db.Uuid
  content   content? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  locationId String?   @db.Uuid
  location   location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  shares share[]

  createdAt DateTime?
}

model share {
  id String @id @default(uuid()) @db.Uuid

  user   user   @relation(fields: [userId], references: [id])
  userId String @db.Uuid

  nodeLocationId String        @db.Uuid
  nodeLocation   node_location @relation(fields: [nodeLocationId], references: [id], onDelete: Cascade)

  post   post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String? @db.Uuid

  likes    content_like[]
  comments content_comment[]
  rates    content_rate[]

  sharedAt DateTime @default(now())
}

model storage {
  userId String @unique @db.Uuid
  user   user   @relation(fields: [userId], references: [id])

  locations location[]
  stats     storage_stats?
  files     file[]
}

model storage_stats {
  storage storage @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId  String  @unique @db.Uuid

  capacity Int
  used     Int
}

model location {
  id String @id @default(uuid()) @db.Uuid

  userId  String?  @db.Uuid
  storage storage? @relation(fields: [userId], references: [userId], onDelete: Cascade)

  path String @db.Citext

  label    location_label?
  contents content[]
  post     post[]

  @@unique([userId, path])
}

model location_label {
  description String
  color       String
  icon        String

  locationId String   @unique @db.Uuid
  location   location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model tag {
  name        String        @unique
  content_tag content_tag[]
}

model content {
  id String @id @default(uuid()) @db.Uuid

  name String @db.Citext
  type String

  userId String @db.Uuid
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label      content_label?
  properties content_properties?
  tags       content_tag[]

  sourceContents  related_contents[] @relation(name: "source_content")
  relatedContents related_contents[] @relation(name: "related_content")

  location   location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String   @db.Uuid

  file file?

  posts post[]

  rates    content_rate[]
  likes    content_like[]
  comments content_comment[]

  interactions content_interactions?

  createdAt DateTime @default(now())

  @@unique([locationId, name])
}

model content_rate {
  rate Int

  userId String @db.Uuid
  user   user   @relation(fields: [userId], references: [id])

  shareId String @db.Uuid
  share   share  @relation(fields: [shareId], references: [id], onDelete: Cascade)

  nodeId String @db.Uuid
  node   node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  contentId String  @db.Uuid
  content   content @relation(fields: [contentId], references: [id])

  @@unique([shareId, userId, nodeId])
}

model content_like {
  userId String @db.Uuid
  user   user   @relation(fields: [userId], references: [id])

  shareId String @db.Uuid
  share   share  @relation(fields: [shareId], references: [id], onDelete: Cascade)

  contentId String  @db.Uuid
  content   content @relation(fields: [contentId], references: [id])

  @@unique([shareId, userId])
}

model content_comment {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   user   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shareId String @db.Uuid
  share   share  @relation(fields: [shareId], references: [id], onDelete: Cascade)

  contentId String  @db.Uuid
  content   content @relation(fields: [contentId], references: [id])

  time Int?   @default(0)
  text String
}

model related_contents {
  sourceContentId String  @db.Uuid
  sourceContent   content @relation(name: "related_content", fields: [sourceContentId], references: [id], onDelete: Cascade)

  relatedContentId String  @db.Uuid
  relatedContent   content @relation(name: "source_content", fields: [relatedContentId], references: [id], onDelete: Cascade)

  @@unique([sourceContentId, relatedContentId])
}

model content_tag {
  content content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     tag     @relation(fields: [name], references: [name], onDelete: Cascade)

  contentId String @db.Uuid
  name      String

  @@unique([contentId, name])
}

model content_properties {
  content   content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId String  @unique @db.Uuid

  properties Json
}

model content_label {
  description String?

  content   content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId String  @unique @db.Uuid
}

model content_interactions {
  content   content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentId String  @unique @db.Uuid

  plays    Int @default(0)
  likes    Int @default(0)
  comments Int @default(0)
  rates    Int @default(0)
  feeders  Int @default(0)
}

model file {
  id String @id @default(uuid()) @db.Uuid

  size         Int
  originalName String
  duration     Int

  url         String
  urlOriginal String

  waveform   waveform?
  properties file_properties?

  userId  String  @db.Uuid
  storage storage @relation(fields: [userId], references: [userId])

  contentId String?  @unique @db.Uuid
  content   content? @relation(fields: [contentId], references: [id], onDelete: Cascade)
}

model file_properties {
  fileId String @unique @db.Uuid
  file   file   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  loudness Float?
  peak     Float?
  channels Int?
}

model waveform {
  fileId String @unique @db.Uuid
  file   file   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  data Bytes
}
